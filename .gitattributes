# Force LF for all text sources so byte-for-byte artifacts stay deterministic
# across clones/checkouts. In particular the SHA-256 pinned in
# run-rtl-patch-local.ps1 (and any hash over the built payload) must not change
# because a checkout silently rewrote LF -> CRLF.
*.ps1  text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
LICENSE text eol=lf
